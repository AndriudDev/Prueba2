<div class="container mt-4">
  <a href="/pacientes" class="btn btn-outline-secondary btn-sm mb-3">← Volver al listado</a>

  <h1 class="mb-3">{{paciente.firstName}} {{paciente.lastName}}</h1>

  <div class="card">
    <div class="card-body">
      <p class="card-text"><strong>Email:</strong> {{paciente.email}}</p>
      <p class="card-text"><strong>Membresía:</strong> {{paciente.membershipType}}</p>
    </div>
  </div>

  <!-- SIMULADOR -->
  <div class="card mt-4 shadow-sm">
    <div class="card-header bg-dark text-white">
      Simulador de presupuesto
    </div>
    <div class="card-body">
      <div class="mb-3">
        <label for="montoTratamiento" class="form-label">Costo del tratamiento ($)</label>
        <input type="number" id="montoTratamiento" class="form-control" placeholder="Ej: 80000">
      </div>

      <div class="p-3 bg-light rounded">
        <p>Descuento aplicado ({{paciente.membershipType}}): 
          <!-- Guardamos el valor en data-porcentaje -->
          <span class="badge bg-success" id="badgeDescuento" data-porcentaje="{{paciente.descuento}}">
            {{paciente.descuento}}%
          </span>
        </p>
        <h4 class="text-primary">Total a pagar: <span id="resultado">$0</span></h4>
      </div>
    </div>
  </div>

  <div class="mt-3 d-flex gap-2">
    <a href="/pacientes/{{paciente.id}}/edit" class="btn btn-warning">Editar</a>
    <form action="/pacientes/{{paciente.id}}/delete" method="POST">
      <button type="submit" class="btn btn-danger">Eliminar</button>
    </form>
  </div>
</div>

<script>
  const inputMonto = document.getElementById('montoTratamiento');
  const spanResultado = document.getElementById('resultado');
  const porcentaje = parseFloat(document.getElementById('badgeDescuento').dataset.porcentaje);

  inputMonto.addEventListener('input', () => {
    const monto = parseFloat(inputMonto.value) || 0;
    const calculo = monto - (monto * (porcentaje / 100));
    
    // Formatear a moneda (ej: $72.000)
    spanResultado.innerText = new Intl.NumberFormat('es-CL', {
      style: 'currency',
      currency: 'CLP'
    }).format(calculo);
  });
</script>