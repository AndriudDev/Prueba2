<div class="container mt-4">
  <a href="/pacientes/{{paciente.id}}" class="btn btn-outline-secondary btn-sm mb-3">← Volver al detalle</a>

  <h1 class="mb-4">Editar: {{paciente.firstName}} {{paciente.lastName}}</h1>

  <form action="/pacientes/{{paciente.id}}/edit" method="POST" class="card card-body">
    <div class="mb-3">
      <label for="firstName" class="form-label">Nombre:</label>
      <input type="text" id="firstName" name="firstName" class="form-control" value="{{paciente.firstName}}" required>
    </div>
    <div class="mb-3">
      <label for="lastName" class="form-label">Apellido:</label>
      <input type="text" id="lastName" name="lastName" class="form-control" value="{{paciente.lastName}}">
    </div>
    <div class="mb-3">
      <label for="email" class="form-label">Email:</label>
      <input type="email" id="email" name="email" class="form-control" value="{{paciente.email}}" required>
    </div>
    <div class="mb-3">
      <label for="membershipType" class="form-label">Membresia:</label>
      <select id="membershipType" name="membershipType" class="form-select" required>
        {{!-- <option value="" disabled selected>Seleccione una membresía</option> --}}
        <option value="{{paciente.membershipType}}" >{{paciente.membershipType}} </option>
        <option value="Silver">Silver</option>
        <option value="Gold">Gold</option>
        <option value="Platinum">Platinum</option>
      </select>
    </div>
    <button type="submit" class="btn btn-primary">Guardar cambios</button>
  </form>
</div>
